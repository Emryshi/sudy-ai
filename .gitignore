# Project specific ignores
# Ignore all model checkpoints and pytorch weights
checkpoints/
# But DO NOT ignore the tokenizer configs since they are required to boot the model
!checkpoints/sudy-tokenizer/

# Ignore large/dynamic datasets and crawls
data/raw/*
!data/raw/turkish_sample.txt

data/processed/*
# Keep starter datasets
!data/processed/sudy_pretrain_starter.txt
!data/processed/sudy_sft_starter.json
!data/processed/turkish_processed.txt

# OS generated files
.DS_Store
Thumbs.db
